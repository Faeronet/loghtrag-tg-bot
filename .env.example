# Telegram — токен от @BotFather
TELEGRAM_BOT_TOKEN=

# С my.telegram.org/apps — только числовой ID и hash (НЕ URL!):
# https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Локальный Bot API на вашем сервере (контейнер telegram-bot-api), НЕ my.telegram.org:
TELEGRAM_API_BASE=http://127.0.0.1:8081
TELEGRAM_API_LOCAL=true
TELEGRAM_REQUEST_TIMEOUT=60
TELEGRAM_CONNECT_RETRIES=5
TELEGRAM_CONNECT_RETRY_DELAY=3
# SOCKS5 прокси для telegram-bot-api (только IP и порт, без логина):
TELEGRAM_PROXY_TYPE=socks5
TELEGRAM_PROXY_HOST=1.2.3.4
TELEGRAM_PROXY_PORT=1080
# Если есть логин/пароль — добавьте в docker-compose command:
# --proxy-login=... --proxy-password=...

# LightRAG (на сервере, при network_mode: host бот ходит напрямую)
LIGHTRAG_URL=http://10.24.0.101:9621
LIGHTRAG_API_KEY=your_lightrag_api_key
LIGHTRAG_QUERY_MODE=mix
LIGHTRAG_TIMEOUT=120

# Embedding bge-m3 (на сервере)
EMBEDDING_URL=http://10.24.0.101:8010
EMBEDDING_MODEL=BAAI/bge-m3

# Qdrant (контейнер, при network_mode: host — через localhost)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=telegram_chat_memory
QDRANT_CONNECT_RETRIES=5
QDRANT_CONNECT_RETRY_DELAY=2

# PostgreSQL (контейнер, переменные задаются на хосте)
POSTGRES_DB=lightrag_bot
POSTGRES_USER=lightrag_bot
POSTGRES_PASSWORD=1234567890
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Путь к системному промпту внутри контейнера
SYSTEM_PROMPT_PATH=/app/prompts/system_prompt.txt

# Лимиты памяти чата
MAX_RECENT_TURNS=6
MAX_RECENT_CHARS=4000
MAX_SUMMARY_CHARS=1500
MAX_RETRIEVED_MEMORIES=3
MEMORY_SCORE_THRESHOLD=0.55
MAX_MEMORY_CONTEXT_CHARS=2500

# Параллельная обработка (сотни одновременных пользователей)
POSTGRES_POOL_MIN=10
POSTGRES_POOL_MAX=100
HTTP_MAX_CONNECTIONS=200
HTTP_MAX_KEEPALIVE=50
